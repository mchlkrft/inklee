NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Format: postgresql://postgres:[PASSWORD]@db.your-project-ref.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-ref.supabase.co:5432/postgres

# Upstash Redis — for rate limiting (optional in dev)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resend — transactional email
RESEND_API_KEY=re_your_api_key
EMAIL_FROM=inklee <noreply@inklee.app>

# Supabase Auth hook secret — set in Supabase dashboard under Auth > Hooks
SUPABASE_AUTH_HOOK_SECRET=your-hook-secret
