# E2E test environment — copy to .env.e2e and fill in.
#
# Playwright loads THIS file (never .env.local, which points at production).
# Point it at an ISOLATED Supabase: the local stack (`supabase start` inside
# apps/web) or a dedicated dev project. The suite hard-refuses the production
# project ref and production hostnames (tests/e2e/helpers/env.ts).
#
# Local stack values (after `supabase start`, printed by `supabase status`):
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Leave external providers UNSET for e2e runs:
# - No RESEND_API_KEY -> app email sending is skipped/logged, nothing real is sent.
# - No STRIPE_SECRET_KEY -> card-deposit paths degrade to their no-Stripe states;
#   the deposit e2e specs cover the manual-deposit path only.
# - No UPSTASH_* -> public-form rate limiting uses the in-memory dev fallback.
#
# Base URL override (optional) — only if the app is already running elsewhere.
# Production hosts are refused.
# E2E_BASE_URL=http://localhost:3000
