{
  "regions": ["fra1"],
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/cleanup",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/reminders",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/lifecycle",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/instagram-refresh",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/retention-purge",
      "schedule": "0 5 1 * *"
    },
    {
      "path": "/api/cron/growth-snapshot",
      "schedule": "30 2 * * *"
    },
    {
      "path": "/api/cron/gsc-sync",
      "schedule": "0 6 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "inkl.ee" }],
      "destination": "https://inklee.app/",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "inkl.ee" }],
      "destination": "https://inklee.app/:path*",
      "permanent": true
    },
    {
      "source": "/impressum",
      "destination": "/imprint",
      "permanent": true
    },
    {
      "source": "/guest-spots",
      "destination": "/guest-spot-booking",
      "permanent": true
    }
  ]
}
