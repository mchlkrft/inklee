# Local dev
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production — set to https://inklee.app in Vercel env vars

# Artist public-bio short domain. When set, public artist URLs are
# emitted as https://<slug>.<bio domain> (subdomain mode). When unset
# or empty, URLs fall back to ${NEXT_PUBLIC_APP_URL}/<slug> (path mode).
# Flip this only after wildcard DNS + SSL are verified end-to-end on
# both Production and Preview environments. See docs/subdomain-deployment.md.
# Production value: inkl.ee
NEXT_PUBLIC_PUBLIC_BIO_DOMAIN=

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SERVER-ONLY — bypasses RLS. Never expose to the browser. Never import from a client component.
# Used exclusively for audit_log inserts from unauthenticated customer actions (src/lib/supabase/service.ts).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Local dev — direct connection, port 5432
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-ref.supabase.co:5432/postgres
# Production (Vercel) — use the POOLED connection, port 6543, transaction mode
# Format: postgresql://postgres.[project-ref]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Find it in Supabase dashboard → Project Settings → Database → Connection string → Transaction mode

# Upstash Redis — for rate limiting (optional in dev)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resend — transactional email
RESEND_API_KEY=re_your_api_key
EMAIL_FROM=inklee <noreply@inklee.app>

# Resend webhook signing secret (Resend dashboard > Webhooks). SERVER-ONLY. Verifies the
# delivery-event webhook at /api/email/webhook (Standard-Webhooks / svix headers). In
# production this is REQUIRED — an unset secret makes the endpoint reject (500). Hard bounces
# and complaints upsert into email_suppressions so campaign sends never re-hit a dead address.
RESEND_WEBHOOK_SECRET=whsec_your_resend_webhook_secret

# Supabase Auth hook secret — set in Supabase dashboard under Auth > Hooks
SUPABASE_AUTH_HOOK_SECRET=your-hook-secret

# Control Tower bridge secret — Bearer token for /api/internal/segments (returns audience
# counts + anonymized samples only, never PII). SERVER-ONLY. Shared with the Control Tower
# vault entry "inklee-internal-api". Leave unset to keep the endpoint fail-closed (401).
CT_BRIDGE_SECRET=your-ct-bridge-secret

# Control Tower campaign-dispatch secret — Standard-Webhooks HMAC secret ("v1,whsec_<base64>"
# or "whsec_<base64>") shared with the Control Tower vault entry "inklee-dispatch". SERVER-ONLY.
# Verifies the signed dispatch POST to /api/internal/email-jobs (real campaign sends) and the
# Bearer read on /api/internal/email-jobs/status. Kept separate from CT_BRIDGE_SECRET so the
# send-triggering capability rotates independently of the read-only preview. Leave UNSET to
# keep both endpoints fail-closed (dispatch -> 500, status -> 500).
CT_DISPATCH_SECRET=

# Campaign real-send master gate. UNSET or anything other than the exact string 'true' means
# campaigns NEVER send real email — a dry-run job still resolves + filters + counts, but the
# endpoint refuses a non-dry job instead of calling Resend. Set to 'true' ONLY after the
# preference/unsubscribe foundation and suppression loop are verified in production. This is
# defense in depth: Control Tower has its own gate; a real send needs BOTH sides on.
EMAIL_CAMPAIGNS_ENABLED=

# Lifecycle email engine master gate (daily cron at /api/cron/lifecycle). UNSET or anything
# other than the exact string 'true' means the cron is a complete no-op: it authenticates,
# returns { disabled: true } and never touches the database or Resend. Set to 'true' ONLY
# after the lifecycle definitions are reviewed (Control Tower exports always arrive as
# 'draft' and each must be deliberately flipped to 'active') and the preference/unsubscribe
# flow is verified in production.
EMAIL_LIFECYCLE_ENABLED=

# Physical postal address printed in the footer of every marketing/lifecycle campaign email
# (CAN-SPAM + Gmail/Yahoo bulk-sender requirement). MUST be set before flipping
# EMAIL_CAMPAIGNS_ENABLED=true — while unset, the footer shows an obvious
# "postal address not configured" placeholder so a dry run flags it. Example:
# EMAIL_POSTAL_ADDRESS="Inklee GmbH, Musterstrasse 1, 10115 Berlin, Germany"
EMAIL_POSTAL_ADDRESS=

# Stripe — deposits + Connect payouts. Use test keys (sk_test_/pk_test_) in dev.
# SERVER-ONLY secret — never expose to the browser, never import client-side.
STRIPE_SECRET_KEY=sk_test_your_secret_key
# Webhook signing secret (Developers > Webhooks). SERVER-ONLY.
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# Publishable key — safe to expose to the client (used by Stripe.js).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Mobile min-version kill-switch (GET /api/mobile/min-version). No OTA exists,
# so this is how a bad build is recalled: set the minimum to just above the bad
# build's version and redeploy; older installs then show a blocking "update
# required" screen on next launch. UNSET = nobody blocked (fail-open) — the
# switch only activates when a minimum is set above a shipped build.
MOBILE_MIN_VERSION=
# Optional per-platform overrides (fall back to MOBILE_MIN_VERSION):
# MOBILE_MIN_VERSION_ANDROID=
# MOBILE_MIN_VERSION_IOS=
# Where the "Update required" screen sends users (APK download page / store).
MOBILE_UPDATE_URL=
