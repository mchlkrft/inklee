{
  "expo": {
    "name": "Inklee",
    "slug": "inklee",
    "owner": "inklee",
    "scheme": "inklee",
    "version": "0.2.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "backgroundColor": "#1e1e1e",
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.inklee",
      "usesAppleSignIn": true
    },
    "android": {
      "package": "app.inklee",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "monochromeImage": "./assets/monochrome-icon.png",
        "backgroundColor": "#1e1e1e"
      },
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "Inklee uses your photos so you can upload flash, portfolio images, and your studio cover."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#e9b22b"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-wordmark-light.png",
          "imageWidth": 220,
          "backgroundColor": "#e5e1d5",
          "dark": {
            "image": "./assets/splash-wordmark-dark.png",
            "backgroundColor": "#1e1e1e"
          }
        }
      ],
      "expo-localization",
      "@maplibre/maplibre-react-native"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "eas": {
        "projectId": "daf44d5c-0134-4815-bc4b-c0524dfcb93f"
      }
    }
  }
}
