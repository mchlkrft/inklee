# Expo / RN
node_modules/
.expo/
dist/
web-build/
expo-env.d.ts

# Native build artifacts (managed workflow regenerates these)
/ios
/android

# Env (EXPO_PUBLIC_* still inlined at build; never commit real keys)
.env
.env.local
.env*.local

# Firebase Android config: low-sensitivity (ships in the APK) but kept out of
# the PUBLIC repo. Local copy lives here; EAS cloud builds receive it via the
# GOOGLE_SERVICES_JSON file env var (see app.config.js). Vault: google-services-inklee.
google-services.json

# App Store Connect API key: SECRET. Referenced by eas.json submit config
# (ascApiKeyPath); restore from the vault (asc-api-key-inklee) on a fresh clone.
asc-api-key.p8

# Metro / misc
*.log
.DS_Store
