# Copy to .env.local (gitignored) and fill in. EXPO_PUBLIC_* are inlined into the
# client bundle at build time — only put PUBLIC values here (anon key, public URL).
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Canonical origin hosting /api/mobile/* — use inklee.app, NOT inkl.ee. The apex
# inkl.ee 308-redirects to inklee.app and fetch drops the Authorization header
# across that redirect, so an inkl.ee API base makes every authed call fail with
# "missing bearer token". For local dev against `pnpm --filter inklee dev`, use
# your machine LAN IP (e.g. http://192.168.x.x:3000), not localhost.
EXPO_PUBLIC_API_URL=https://inklee.app
# Base for the artist's PUBLIC links (booking/hub/waitlist), whose subdomains
# live on inkl.ee (<slug>.inkl.ee, <slug>.l.inkl.ee). Falls back to the API base
# when unset. Keep this on inkl.ee even though the API is on inklee.app.
EXPO_PUBLIC_PUBLIC_BASE_URL=https://inkl.ee
